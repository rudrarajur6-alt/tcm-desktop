{
  "name": "the-cloud-market",
  "version": "1.1.0",
  "main": "main.js",
  "description": "The Cloud Market — Your Workspace. Your Data. Your Cloud.",
  "author": "The Cloud Market <support@thecloud.market>",
  "license": "AGPL-3.0",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build-win": "electron-builder --win nsis --publish never",
    "build-mac": "electron-builder --mac",
    "build-all": "electron-builder --win --mac"
  },
  "build": {
    "appId": "market.thecloud.workspace",
    "productName": "The Cloud Market",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.ico"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "icon.png",
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "The Cloud Market"
    },
    "protocols": [
      {
        "name": "The Cloud Market",
        "schemes": ["tcmworkspace"]
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icon.ico",
      "icon.png"
    ]
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  }
}
