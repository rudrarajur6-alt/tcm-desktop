{
  "name": "the-cloud-market",
  "version": "1.0.0",
  "main": "main.js",
  "description": "The Cloud Market — Your Workspace. Your Data. Your Cloud.",
  "author": "The Cloud Market <support@thecloud.market>",
  "license": "AGPL-3.0",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build-win": "electron-builder --win nsis",
    "build-mac": "electron-builder --mac",
    "build-all": "electron-builder --win --mac"
  },
  "build": {
    "appId": "market.thecloud.workspace",
    "productName": "The Cloud Market",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": ["nsis"],
      "icon": "icon.png"
    },
    "mac": {
      "target": ["dmg"],
      "icon": "icon.png",
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "The Cloud Market"
    }
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1"
  }
}
